DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# ── LLM provider (auto-detected by priority: anthropic > openai > groq > mock)
# Provide ONE key. If none are set, the app runs in deterministic MOCK mode.
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."
# GROQ_API_KEY="gsk_..."

# Optional model overrides (sensible defaults are used per provider)
# LLM_MODEL="claude-haiku-4-5-20251001"

# ── Server ─────────────────────────────────────────────────────────────────
PORT=4000
